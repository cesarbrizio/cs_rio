{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmitOnError": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@cs-rio/domain/*": [
        "packages/domain/src/*"
      ],
      "@cs-rio/platform/*": [
        "packages/platform/src/*"
      ],
      "@cs-rio/ui/*": [
        "packages/ui/src/*"
      ],
      "@domain/*": [
        "packages/domain/src/*"
      ],
      "@platform/*": [
        "packages/platform/src/*"
      ],
      "@ui/*": [
        "packages/ui/src/*"
      ],
      "@shared/*": [
        "packages/shared/src/*"
      ],
      "@engine/*": [
        "packages/game-engine/src/*"
      ]
    }
  }
}
