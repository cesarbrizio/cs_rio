{
  "name": "@cs-rio/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:seed": "tsx src/db/seed.ts",
    "lint": "eslint \"src/**/*.ts\" \"drizzle.config.ts\" \"test/**/*.ts\"",
    "ops:alias": "tsx src/scripts/alias-command.ts",
    "ops:audit": "tsx src/scripts/audit-command.ts",
    "ops:config": "tsx src/scripts/config-command.ts",
    "ops:player": "tsx src/scripts/player-command.ts",
    "ops:quick": "tsx src/scripts/presets-command.ts",
    "ops:round": "tsx src/scripts/round-command.ts",
    "ops:scenario": "tsx src/scripts/scenario-command.ts",
    "ops:starter": "tsx src/scripts/scenario-command.ts --apply starter-pack",
    "ops:help": "tsx src/scripts/help-command.ts",
    "ops:world": "tsx src/scripts/world-command.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "node -e \"console.log('server: nothing to clean yet')\""
  },
  "dependencies": {
    "@colyseus/schema": "^4.0.17",
    "@cs-rio/shared": "file:../../packages/shared",
    "@fastify/cors": "^11.1.0",
    "bcrypt": "^5.1.1",
    "colyseus": "^0.17.8",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "pg": "^8.14.1",
    "redis": "^5.1.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.31.0"
  }
}
