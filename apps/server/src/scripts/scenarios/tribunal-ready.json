{
  "name": "tribunal-ready",
  "description": "Facção e favela preparadas para gerar e julgar casos do tribunal.",
  "extends": ["starter-pack"],
  "defaults": {
    "factionBankMoney": 250000,
    "factionCode": "cv",
    "factionInternalSatisfaction": 68,
    "factionPoints": 900,
    "favelaBandits": 120,
    "favelaCode": "morro_da_providencia",
    "favelaSatisfaction": 56,
    "regionId": "centro"
  },
  "requires": ["player"],
  "steps": [
    {
      "kind": "world",
      "description": "Posiciona o jogador como liderança operacional da facção.",
      "selector": {
        "player": "$player"
      },
      "commands": [
        { "type": "join-faction", "value": "$factionCode" },
        { "type": "set-rank", "value": "general" },
        { "type": "set-faction-bank-money", "value": "$factionBankMoney" },
        { "type": "set-faction-points", "value": "$factionPoints" },
        { "type": "set-faction-internal-satisfaction", "value": "$factionInternalSatisfaction" }
      ]
    },
    {
      "kind": "world",
      "description": "Entrega uma favela controlada e viva para o tribunal.",
      "selector": {
        "favelaCode": "$favelaCode"
      },
      "commands": [
        { "type": "set-favela-controller", "value": "$factionCode" },
        { "type": "set-favela-state", "value": "controlled" },
        { "type": "set-favela-satisfaction", "value": "$favelaSatisfaction" },
        { "type": "set-bandits", "value": "$favelaBandits" }
      ]
    }
  ]
}
