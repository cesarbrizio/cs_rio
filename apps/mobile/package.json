{
  "name": "@cs-rio/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "node ./scripts/run-expo-with-root-env.mjs start --clear",
    "generate:map-structures": "node ./scripts/generate-map-structure-svgs.mjs",
    "build": "tsc --noEmit && node -e \"const fs=require('node:fs'); fs.mkdirSync('build',{recursive:true}); fs.writeFileSync('build/.stamp','mobile-bootstrap');\"",
    "lint": "eslint \"App.tsx\" \"src/**/*.{ts,tsx}\" \"test/**/*.ts\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"console.log('mobile: nothing to clean yet')\"",
    "android": "node ./scripts/run-expo-with-root-env.mjs run:android",
    "ios": "node ./scripts/run-expo-with-root-env.mjs run:ios"
  },
  "dependencies": {
    "@cs-rio/game-engine": "file:../../packages/game-engine",
    "@cs-rio/shared": "file:../../packages/shared",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "@shopify/react-native-skia": "1.5.0",
    "axios": "^1.8.4",
    "colyseus.js": "^0.16.22",
    "expo": "~52.0.49",
    "expo-asset": "~11.0.5",
    "expo-av": "~15.0.2",
    "expo-constants": "~17.0.8",
    "expo-dev-client": "~5.0.20",
    "expo-dev-launcher": "^5.0.35",
    "expo-dev-menu": "^6.0.25",
    "expo-dev-menu-interface": "^1.9.3",
    "expo-haptics": "~14.0.1",
    "expo-manifests": "^0.15.8",
    "expo-notifications": "~0.29.14",
    "expo-secure-store": "~14.0.1",
    "expo-status-bar": "~2.0.1",
    "expo-updates-interface": "^1.0.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-game-engine": "^1.2.0",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/plugin-transform-class-static-block": "^7.28.6",
    "@types/react": "^18.3.18",
    "babel-plugin-module-resolver": "^5.0.2",
    "dotenv": "^16.4.7"
  }
}
