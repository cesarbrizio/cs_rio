{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "resolveJsonModule": true,
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@cs-rio/domain/*": [
        "../../packages/domain/src/*"
      ],
      "@cs-rio/platform/*": [
        "../../packages/platform/src/*"
      ],
      "@cs-rio/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@domain/*": [
        "../../packages/domain/src/*"
      ],
      "@platform/*": [
        "../../packages/platform/src/*"
      ],
      "@ui/*": [
        "../../packages/ui/src/*"
      ],
      "@shared/*": [
        "../../packages/shared/src/*"
      ],
      "@engine/*": [
        "../../packages/game-engine/src/*"
      ]
    },
    "types": [
      "node"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
