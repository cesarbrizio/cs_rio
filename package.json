{
  "name": "cs-rio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "apps/editor",
    "apps/mobile",
    "apps/desktop",
    "packages/*"
  ],
  "scripts": {
    "db:fresh": "npm --prefix ../cs_rio_api run db:fresh",
    "db:fresh:test": "npm --prefix ../cs_rio_api run db:fresh:test",
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "generate": "turbo run generate",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "dependencies": {
    "expo": "~52.0.49",
    "react": "18.3.1",
    "react-native": "0.76.9"
  }
}
