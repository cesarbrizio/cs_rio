{
  "name": "@cs-rio/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./hooks": {
      "types": "./src/hooks/index.ts",
      "default": "./src/hooks/index.ts"
    },
    "./providers": {
      "types": "./src/providers/index.ts",
      "default": "./src/providers/index.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@cs-rio/domain": "file:../domain",
    "@cs-rio/game-engine": "file:../game-engine",
    "@cs-rio/platform": "file:../platform",
    "@cs-rio/shared": "file:../shared",
    "react": "18.3.1"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "lint": "eslint --no-error-on-unmatched-pattern \"src/**/*.{ts,tsx}\" \"test/**/*.{ts,tsx}\"",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "node -e \"console.log('ui: nothing to clean yet')\""
  }
}
