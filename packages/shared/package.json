{
  "name": "@cs-rio/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "npm run generate && tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "generate": "tsx ./scripts/generate-structure-svgs.ts",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "node -e \"console.log('shared: nothing to clean yet')\""
  }
}
